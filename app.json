{
	"expo": {
		"name": "FDA-Drivers",
		"slug": "fda-drivers",
		"owner": "ft_lantonio",
		"version": "1.0.0",
		"scheme": "fda-drivers",
		"orientation": "portrait",
		"icon": "./assets/images/logo.png",
		"userInterfaceStyle": "automatic",
		"newArchEnabled": true,
